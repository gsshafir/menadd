---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { meta, sections } from "../data";

const articles = (await getCollection("articles", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title={meta.library.title} description={meta.library.description} canonical="/library/">
  <section>
    <h1>The Diligence Library</h1>
    <p class="lede">Diligence for MENA founders, organized the way a diligence report is organized: ownership, control, structure, cash, process.</p>
    <div class="section-list">
      {
        sections.map((section) => (
          <div class="section-entry">
            <h3><a href={section.href}>{section.title}</a></h3>
            <p>{section.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section>
    <h2>Articles</h2>
    <div class="article-list">
      {
        articles.map((article) => (
          <article class="article-entry">
            <h3><a href={`/library/${article.data.section}/${article.id}/`}>{article.data.title}</a></h3>
            <p>{article.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</Base>
