---
import { getCollection } from "astro:content";
import Section from "../../../layouts/Section.astro";
import { sections } from "../../../data";

const section = sections.find((item) => item.key === "structure")!;
const articles = (await getCollection("articles", ({ data }) => data.section === "structure" && !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Section sectionKey="structure" title={section.title} description={section.description} articles={articles} />
